{
  "name": "ngx-loading-buttons",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build ngx-loading-buttons-playground",
    "build:ngx-loading-buttons": "ng-packagr -p projects/ngx-loading-buttons/ng-package.json && cd projects/ngx-loading-buttons && npm run build",
    "test:ngx-loading-buttons": "ng test ngx-loading-buttons --karma-config  projects/ngx-loading-buttons/karma.conf.js  --watch=false",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "engines": {
    "node": "^20.11.1 || ^22.10.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@types/jasmine": "~3.10.0",
    "@types/node": "^22.15.31",
    "copyfiles": "^2.4.1",
    "jasmine-core": "~3.10.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~4.0.2",
    "karma-jasmine-html-reporter": "~1.7.0",
    "ng-packagr": "^21.2.1",
    "typescript": "~5.9.3"
  }
}
